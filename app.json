{
  "expo": {
    "name": "Maktapty",
    "slug": "Maktapty",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "library",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#633a19"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yourname.library"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#633a19"
      },
      "package": "com.yourname.library"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
